# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Resend API Key (for newsletter)
RESEND_API_KEY=your_resend_api_key_here

# Newsletter settings
NEWSLETTER_FROM_EMAIL=newsletter@christosmentis.com
NEWSLETTER_REPLY_TO=info@christosmentis.com

# Neon Postgres (books + auth tables)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Better Auth (self-hosted)
# In production set BETTER_AUTH_URL to the public site URL (reset emails use this)
BETTER_AUTH_SECRET=generate_with_openssl_rand_base64_32
BETTER_AUTH_URL=http://localhost:3000

# Author account (used by seed script only)
ADMIN_EMAIL=author@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# Vercel Blob — required for admin cover uploads
# Create a Blob store in the Vercel dashboard for this project, then either:
#   - Link the store (auto-injects BLOB_READ_WRITE_TOKEN), or
#   - Copy the read-write token into .env.local and Vercel project env (Production + Preview)
# Without this token, upload fails; you can still paste a cover path/URL manually.
BLOB_READ_WRITE_TOKEN=
